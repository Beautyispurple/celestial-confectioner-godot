; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Celestial Confectioner"
run/main_scene="uid://b78h6nfewsk12"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"
QuestSystem="*uid://b77kvbliweux5"
VFX="*uid://ecyiymmaj3jv"
EnvVFX="*uid://qomyut16hnoi"
PsxVisualsGd4AutoLoad="uid://dj3bxpmibqxum"
PsxVisualsGd4AutoApply="uid://stww83i1wsru"

[dialogic]

directories/dch_directory={
"character_taffy": "res://sprite_character/taffy_sprite/character_taffy.dch",
"marzi": "res://marzi.dch"
}
directories/dtl_directory={
"celestial_confectioner_timeline": "res://celestial_confectioner_timeline.dtl",
"intro_sequence": "res://intro_sequence.dtl"
}
layout/style_directory={
"": "res://visualnovelwithportrait.tres",
"marzi_visual_novel_style": "res://marzi_visual_novel_style.tres",
"real_marzi_style": "res://real_marzi_style.tres",
"visualnovelwithportrait": "res://visualnovelwithportrait.tres"
}
layout/style_list=["res://visualnovelwithportrait.tres", "res://marzi_visual_novel_style.tres", "res://real_marzi_style.tres"]
layout/default_style="res://visualnovelwithportrait.tres"
glossary/default_case_sensitive=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/FancyControls/plugin.cfg", "res://addons/ai_coding_assistant/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/psx_visuals_gd4/plugin.cfg", "res://addons/quest_system/plugin.cfg", "res://addons/uiJuicer/plugin.cfg", "res://addons/vfx_library/plugin.cfg", "res://addons/wyvernbox/editor/plugin.cfg")

